---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { categoryMeta, categoryOrder } from '../lib/categories';
import { getLocaleFromPath, localeBase, switchLocalePath, ui } from '../lib/i18n';
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = '索', description = '', image = '' } = Astro.props;
const siteTitle = '索|blog';
const formattedTitle = title.replace(/\s*\|\s*索\|blog$/, '').replace(/\s*-\s*索$/, '');
const siteUrl = 'https://blog.mtdnot.dev';
const ogImage = image || `${siteUrl}/avatar.png`;
const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);
const t = ui[locale];
const base = localeBase(locale);
const allPosts = await getCollection('posts');
const tree = categoryOrder.map((key) => ({
  key,
  label: categoryMeta[key].label[locale],
  posts: allPosts
    .filter((post) => post.data.category === key)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
}));
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{formattedTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/avatar.png" />
  
  <!-- OGP -->
  <meta property="og:title" content={formattedTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content={siteTitle} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={formattedTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
</head>
<body>
  <header class="site-header">
    <nav class="site-nav">
      <a href={`${base || ''}/`.replace(/\/+/g, '/')}>{t.home}</a>
      <a href={`${base}/about/`.replace(/\/+/g, '/')}>{t.about}</a>
      <a href={`${base}/products/`.replace(/\/+/g, '/')}>{t.products}</a>
      <a href={`${base}/slides/`.replace(/\/+/g, '/')}>{t.slides}</a>
      <a href={`${base}/promise/`.replace(/\/+/g, '/')}>{t.promise}</a>
      <a href={`${base}/notice/`.replace(/\/+/g, '/')}>{t.notice}</a>
    </nav>
    <a href={`${base || ''}/`.replace(/\/+/g, '/')} class="site-title" aria-label="あなぐる">
      <ruby>索<rt>あなぐる</rt></ruby>
    </a>
    <nav class="site-locale-nav" aria-label="language switcher">
      <a href={switchLocalePath(pathname, 'ja')} class:list={['locale-link', { 'is-active': locale === 'ja' }]}>JA</a>
      <a href={switchLocalePath(pathname, 'en')} class:list={['locale-link', { 'is-active': locale === 'en' }]}>EN</a>
    </nav>
  </header>
  <div class="container">
    <aside class="tree-sidebar">
      <div class="tree-root">
        <a href={`${base || ''}/`.replace(/\/+/g, '/')} class:list={['tree-root-link', { 'is-active': pathname === '/' || pathname === '/en/' }]}>
          {t.allPosts}
        </a>
      </div>
      <div class="tree-groups">
        {tree.map((group) => {
          const categoryPath = `${base}/${group.key}/`.replace(/\/+/g, '/');
          const postPathPrefix = `${base}/posts/`.replace(/\/+/g, '/');
          const articlePathPrefix = `${base}/article/`.replace(/\/+/g, '/');
          const isCategoryActive = pathname.startsWith(categoryPath) || pathname.startsWith(postPathPrefix) || pathname.startsWith(articlePathPrefix);
          return (
            <details class="tree-group" open={isCategoryActive}>
              <summary>
                <a href={categoryPath} class:list={['tree-category-link', { 'is-active': pathname.startsWith(categoryPath) }]}>
                  {group.label}
                </a>
              </summary>
              <ul class="tree-posts">
                {group.posts.map((post) => (
                  <li>
                    <a
                      href={`${base}/posts/${post.id}/`.replace(/\/+/g, '/')}
                      class:list={['tree-post-link', { 'is-active': pathname === `${base}/posts/${post.id}/`.replace(/\/+/g, '/') || pathname === `${base}/article/${post.id}/`.replace(/\/+/g, '/') }]}
                    >
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          );
        })}
      </div>
    </aside>
    <main class="main">
      <slot />
    </main>
  </div>
  <footer class="site-footer">
    <div class="site-footer-inner">©mtdnot</div>
  </footer>
  <div class="image-lightbox" hidden aria-hidden="true">
    <button class="image-lightbox-close" type="button" aria-label="Close image">×</button>
    <img class="image-lightbox-image" alt="">
  </div>
  <script is:inline>
    const lightbox = document.querySelector('.image-lightbox');
    const lightboxImage = lightbox?.querySelector('.image-lightbox-image');
    const closeButton = lightbox?.querySelector('.image-lightbox-close');

    const openLightbox = (image) => {
      if (!lightbox || !lightboxImage) return;
      lightboxImage.src = image.currentSrc || image.src;
      lightboxImage.alt = image.alt || '';
      lightbox.hidden = false;
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.classList.add('lightbox-open');
    };

    const closeLightbox = () => {
      if (!lightbox || !lightboxImage) return;
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImage.src = '';
      lightboxImage.alt = '';
      document.body.classList.remove('lightbox-open');
    };

    document.querySelectorAll('.post-content img, .content img').forEach((image) => {
      image.classList.add('zoomable-image');
      image.addEventListener('click', () => openLightbox(image));
    });

    closeButton?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox) {
        closeLightbox();
      }
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox && !lightbox.hidden) {
        closeLightbox();
      }
    });
  </script>
</body>
</html>
