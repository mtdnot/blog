---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = 'mtdnot blog', description = '', image = '' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const siteUrl = 'https://blog.mtdnot.dev';
const ogImage = image || `${siteUrl}/avatar.png`;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- OGP -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="mtdnot blog" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
</head>
<body>
  <header class="site-header">
    <nav class="site-nav">
      <a href={base}>ホーム</a>
      <a href={`${base}about/`}>About</a>
      <a href={`${base}promise/`}>約束</a>
      <a href={`${base}notice/`}>利用表記</a>
    </nav>
  </header>
  <div class="container">
    <main class="main">
      <slot />
    </main>
  </div>
  <footer class="site-footer">
    <div class="site-footer-inner">©mtdnot</div>
  </footer>
</body>
</html>
