---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { categoryMeta, categoryOrder } from '../lib/categories';
import { getLocaleFromPath, localeBase, switchLocalePath, ui } from '../lib/i18n';
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = 'mtdnot blog', description = '', image = '' } = Astro.props;
const siteUrl = 'https://blog.mtdnot.dev';
const ogImage = image || `${siteUrl}/avatar.png`;
const pathname = Astro.url.pathname;
const locale = getLocaleFromPath(pathname);
const t = ui[locale];
const base = localeBase(locale);
const allPosts = await getCollection('posts');
const tree = categoryOrder.map((key) => ({
  key,
  label: categoryMeta[key].label[locale],
  posts: allPosts
    .filter((post) => post.data.category === key)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
}));
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- OGP -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="mtdnot blog" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
</head>
<body>
  <header class="site-header">
    <nav class="site-nav">
      <a href={`${base || ''}/`.replace(/\/+/g, '/')}>{t.home}</a>
      <a href={`${base}/about/`.replace(/\/+/g, '/')}>{t.about}</a>
      <a href={`${base}/products/`.replace(/\/+/g, '/')}>{t.products}</a>
      <a href={`${base}/slides/`.replace(/\/+/g, '/')}>{t.slides}</a>
      <a href={`${base}/promise/`.replace(/\/+/g, '/')}>{t.promise}</a>
      <a href={`${base}/notice/`.replace(/\/+/g, '/')}>{t.notice}</a>
    </nav>
    <a href={`${base || ''}/`.replace(/\/+/g, '/')} class="site-title" aria-label="あなぐる">
      <ruby>索<rt>あなぐる</rt></ruby>
    </a>
    <nav class="site-locale-nav" aria-label="language switcher">
      <a href={switchLocalePath(pathname, 'ja')} class:list={['locale-link', { 'is-active': locale === 'ja' }]}>JA</a>
      <a href={switchLocalePath(pathname, 'en')} class:list={['locale-link', { 'is-active': locale === 'en' }]}>EN</a>
    </nav>
  </header>
  <div class="container">
    <aside class="tree-sidebar">
      <div class="tree-root">
        <a href={`${base || ''}/`.replace(/\/+/g, '/')} class:list={['tree-root-link', { 'is-active': pathname === '/' || pathname === '/en/' }]}>
          {t.allPosts}
        </a>
      </div>
      <div class="tree-groups">
        {tree.map((group) => {
          const categoryPath = `${base}/${group.key}/`.replace(/\/+/g, '/');
          const postPathPrefix = `${base}/posts/`.replace(/\/+/g, '/');
          const articlePathPrefix = `${base}/article/`.replace(/\/+/g, '/');
          const isCategoryActive = pathname.startsWith(categoryPath) || pathname.startsWith(postPathPrefix) || pathname.startsWith(articlePathPrefix);
          return (
            <details class="tree-group" open={isCategoryActive}>
              <summary>
                <a href={categoryPath} class:list={['tree-category-link', { 'is-active': pathname.startsWith(categoryPath) }]}>
                  {group.label}
                </a>
              </summary>
              <ul class="tree-posts">
                {group.posts.map((post) => (
                  <li>
                    <a
                      href={`${base}/posts/${post.id}/`.replace(/\/+/g, '/')}
                      class:list={['tree-post-link', { 'is-active': pathname === `${base}/posts/${post.id}/`.replace(/\/+/g, '/') || pathname === `${base}/article/${post.id}/`.replace(/\/+/g, '/') }]}
                    >
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          );
        })}
      </div>
    </aside>
    <main class="main">
      <slot />
    </main>
  </div>
  <footer class="site-footer">
    <div class="site-footer-inner">©mtdnot</div>
  </footer>
</body>
</html>
