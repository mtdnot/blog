---
import Base from '../layouts/Base.astro';
import { getSpeakerDeckEmbeds, speakerDeckProfileUrl } from '../lib/speakerdeck';

const speakerDeckEmbeds = await getSpeakerDeckEmbeds();

const slideItems = [
  {
    name: '自己紹介LT',
    href: 'https://apps.mtdnot.dev/apps/intromyselfLTrevealjs/',
  },
  {
    name: '大LT',
    href: 'https://apps.mtdnot.dev/apps/%E5%A4%A7LTrevealjs4up/#/',
  },
];
---

<Base title="Slides - 索" description="PDF では表現しづらいスライドや資料の一覧。">
  <section class="catalog-page">
    <header class="catalog-header">
      <h1>Slides</h1>
      <p>PDF では表現しづらいスライドや、動きのある資料を置くためのページです。</p>
    </header>

    <div class="catalog-grid">
      {slideItems.map((item) => (
        <a class="catalog-card catalog-link-card" href={item.href} target="_blank" rel="noreferrer">
          <h2>{item.name}</h2>
        </a>
      ))}
    </div>

    <section class="speakerdeck-section">
      <div class="section-heading">
        <h2>SpeakerDeck</h2>
        <a href={speakerDeckProfileUrl} target="_blank" rel="noreferrer">speakerdeck.com/mtdnot</a>
      </div>

      <div class="speakerdeck-grid">
        {speakerDeckEmbeds.map((item) => (
          <article class="speakerdeck-card">
            <h3>{item.title}</h3>
            {item.html ? (
              <div class="speakerdeck-embed" set:html={item.html} />
            ) : (
              <a class="speakerdeck-fallback" href={item.url} target="_blank" rel="noreferrer">
                SpeakerDeck で開く
              </a>
            )}
          </article>
        ))}
      </div>
    </section>
  </section>
</Base>

<style>
  .catalog-page {
    max-width: 760px;
  }

  .catalog-header {
    margin-bottom: 2rem;
  }

  .catalog-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }

  .catalog-header p {
    color: #b8b8b8;
  }

  .catalog-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.4rem;
  }

  .catalog-card {
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    background: #171717;
    padding: 1rem 1.1rem;
  }

  .catalog-link-card {
    color: inherit;
    text-decoration: none;
  }

  .catalog-link-card:hover {
    text-decoration: none;
    border-color: #4a4a4a;
    background: #1b1b1b;
  }

  .catalog-card h2 {
    font-size: 1rem;
  }

  .speakerdeck-section {
    display: grid;
    gap: 1rem;
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-heading h2 {
    font-size: 1.2rem;
  }

  .section-heading a {
    color: #8b8b8b;
    font-size: 0.9rem;
  }

  .speakerdeck-grid {
    display: grid;
    gap: 1rem;
  }

  .speakerdeck-card {
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    background: #171717;
    padding: 1rem 1.1rem;
  }

  .speakerdeck-card h3 {
    font-size: 1rem;
    margin-bottom: 0.85rem;
  }

  .speakerdeck-embed :global(iframe) {
    display: block;
    width: 100%;
    min-height: 420px;
    border: 0;
    border-radius: 10px;
    background: #101010;
  }

  .speakerdeck-fallback {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
  }

  @media (max-width: 720px) {
    .speakerdeck-embed :global(iframe) {
      min-height: 280px;
    }
  }
</style>
