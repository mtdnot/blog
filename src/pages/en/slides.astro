---
import Base from '../../layouts/Base.astro';

const slideItems = [
  {
    name: 'Intro myself LT',
    href: 'https://apps.mtdnot.dev/apps/intromyselfLTrevealjs/',
  },
  {
    name: '大LT',
    href: 'https://apps.mtdnot.dev/apps/%E5%A4%A7LTrevealjs4up/#/',
  },
];
---

<Base title="Slides - 索" description="A list of slides and materials that work better outside PDF.">
  <section class="catalog-page">
    <header class="catalog-header">
      <h1>Slides</h1>
      <p>This page is for slides with motion, interaction, or structure that do not fit PDF well.</p>
    </header>

    <div class="catalog-grid">
      {slideItems.map((item) => (
        <a class="catalog-card catalog-link-card" href={item.href} target="_blank" rel="noreferrer">
          <h2>{item.name}</h2>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .catalog-page {
    max-width: 760px;
  }

  .catalog-header {
    margin-bottom: 2rem;
  }

  .catalog-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }

  .catalog-header p {
    color: #b8b8b8;
  }

  .catalog-grid {
    display: grid;
    gap: 1rem;
  }

  .catalog-card {
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    background: #171717;
    padding: 1rem 1.1rem;
  }

  .catalog-link-card {
    color: inherit;
    text-decoration: none;
  }

  .catalog-link-card:hover {
    text-decoration: none;
    border-color: #4a4a4a;
    background: #1b1b1b;
  }

  .catalog-card h2 {
    font-size: 1rem;
  }
</style>
