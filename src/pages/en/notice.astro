---
import Base from '../../layouts/Base.astro';
---

<Base title="Credits - mtdnot blog" description="Credits for the font and framework used on this site.">
  <article class="notice-page">
    <h1>Credits</h1>
    <p>This site uses the following font and software.</p>

    <section>
      <h2>Font</h2>
      <p>The body text uses <strong>03 SmartFontUI / SmartFontUI</strong>.</p>
      <p>Based on the bundled readme, SmartFontUI is presented as an OpenType font derived from IPAex Gothic.</p>
    </section>

    <section>
      <h2>Framework</h2>
      <p>This site is built with <strong>Astro</strong>.</p>
    </section>
  </article>
</Base>

<style>
  .notice-page {
    max-width: 720px;
  }

  .notice-page h1 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .notice-page h2 {
    font-size: 1.1rem;
    margin: 2rem 0 0.75rem;
  }

  .notice-page p {
    color: #b8b8b8;
    margin-bottom: 0.75rem;
  }
</style>
