---
import Base from '../../layouts/Base.astro';
---

<Base title="About - 索">
  <div class="author-card">
    <img src="/avatar.png" alt="mtdnot" class="avatar">
    <div class="author-name">mtdnot</div>
  </div>
  <h1>About</h1>
  <p>This is mtdnot's technical blog.</p>
  <p>I write about AI, complex systems, NixOS, and multi-agent systems.</p>
  
  <h2>Author</h2>
  <ul>
    <li><a href="https://github.com/mtdnot">GitHub</a></li>
    <li><a href="https://x.com/mtdnot">X</a></li>
    <li><a href="https://mtdnot.dev/">personal portfolio</a></li>
  </ul>
</Base>

<style>
  .author-card {
    margin-bottom: 2rem;
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    margin-bottom: 0.75rem;
  }

  .author-name {
    font-size: 1.25rem;
    font-weight: 700;
  }
</style>
