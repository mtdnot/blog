---
import Base from '../../layouts/Base.astro';

const products = [
  {
    name: 'AI Chat Application',
    note: 'AI-powered chat platform using OpenAI API',
    links: [
      { label: 'Live Demo', href: 'https://chat.mtdnot.dev/' },
      { label: 'GitHub', href: 'https://github.com/mtdnot/AIChatApp' },
    ],
  },
  {
    name: 'CNC Pen Plotter',
    note: 'Mechanical device using G-code',
    links: [
      { label: 'Demo Video', href: 'https://www.youtube.com/watch?v=cvTdwgvXVYw' },
    ],
  },
  {
    name: 'Fractal Tree',
    note: 'Using OpenGL to render recursive structures',
    links: [
      { label: 'Demo Video', href: 'https://youtu.be/BvySqiAc7FI' },
    ],
  },
  {
    name: 'Club Website',
    note: 'Websites and apps made during high school club activities.',
    links: [
      { label: 'NCC', href: 'https://apps.mtdnot.dev/ncc/' },
      { label: 'AI chat with live2d', href: 'https://apps.mtdnot.dev/chat/' },
      { label: 'chart8 (medical care and depopulation in Mie)', href: 'https://apps.mtdnot.dev/chart8/' },
      { label: 'wordcounter', href: 'https://apps.mtdnot.dev/wordcounter/' },
    ],
  },
];
---

<Base title="Products - 索" description="A list of products published by mtdnot.">
  <section class="catalog-page">
    <header class="catalog-header">
      <h1>Products</h1>
      <p>A page for collecting apps and products that are publicly available.</p>
    </header>

    <div class="catalog-grid">
      {products.map((product) => (
        <article class="catalog-card">
          <h2>{product.name}</h2>
          <p>{product.note}</p>
          <div class="catalog-links">
            {product.links.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .catalog-page {
    max-width: 760px;
  }

  .catalog-header {
    margin-bottom: 2rem;
  }

  .catalog-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }

  .catalog-header p,
  .catalog-card p {
    color: #b8b8b8;
  }

  .catalog-grid {
    display: grid;
    gap: 1rem;
  }

  .catalog-card {
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    background: #171717;
    padding: 1rem 1.1rem;
  }

  .catalog-card h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
  }

  .catalog-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.9rem;
  }
</style>
