---
import Base from '../../layouts/Base.astro';
import { getDocuments, getDocument, getAssetUrl } from '../../lib/directus';
import { marked } from 'marked';

export async function getStaticPaths() {
  const docs = await getDocuments();
  return docs.map(doc => ({
    params: { slug: doc.slug },
  }));
}

const { slug } = Astro.params;
const doc = await getDocument(slug);

if (!doc) {
  return Astro.redirect('/docs');
}

// Directusの画像パスを変換
// /assets/xxx → https://directus.mtdnot.dev/assets/xxx
// ![](assets/xxx) → https://directus.mtdnot.dev/assets/xxx
let content = doc.content;
content = content.replace(/!\[([^\]]*)\]\(\/assets\/([^)]+)\)/g, '![$1](https://directus.mtdnot.dev/assets/$2)');
content = content.replace(/!\[([^\]]*)\]\(assets\/([^)]+)\)/g, '![$1](https://directus.mtdnot.dev/assets/$2)');
// UUID形式の画像IDも対応
content = content.replace(/!\[([^\]]*)\]\(([a-f0-9-]{36})\)/g, '![$1](https://directus.mtdnot.dev/assets/$2)');

const htmlContent = marked.parse(content);

const clearanceLabels: Record<number, string> = {
  0: 'PUBLIC',
  1: 'INTERNAL',
  2: 'CONFIDENTIAL',
  3: 'SECRET',
  4: 'TOP SECRET',
  5: 'CLASSIFIED',
};

const clearanceColors: Record<number, string> = {
  0: '#4caf50',
  1: '#2196f3',
  2: '#ff9800',
  3: '#f44336',
  4: '#9c27b0',
  5: '#000000',
};
---

<Base title={doc.title}>
  <article>
    <header>
      <div class="header-meta">
        <span class="clearance-badge" style={`background: ${clearanceColors[doc.clearance ?? 0]}`}>
          L{doc.clearance ?? 0} {clearanceLabels[doc.clearance ?? 0]}
        </span>
      </div>
      <h1>{doc.title}</h1>
      <div class="meta">
        <time>{new Date(doc.date_created).toLocaleDateString('ja-JP')}</time>
        {doc.date_updated && (
          <span class="updated">
            (更新: {new Date(doc.date_updated).toLocaleDateString('ja-JP')})
          </span>
        )}
      </div>
      {doc.tags && doc.tags.length > 0 && (
        <div class="tags">
          {doc.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    
    {doc.cover_image && (
      <img src={getAssetUrl(doc.cover_image)} alt={doc.title} class="cover" />
    )}
    
    <div class="content" set:html={htmlContent} />
    
    <footer>
      <a href="/docs">← ドキュメント一覧に戻る</a>
    </footer>
  </article>
</Base>

<style>
  article {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #333;
  }
  
  .header-meta {
    margin-bottom: 0.5rem;
  }
  
  .clearance-badge {
    color: white;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
  }
  
  h1 {
    margin-bottom: 0.5rem;
    color: #fff;
  }
  
  .meta {
    color: #888;
    font-size: 0.9rem;
  }
  
  .updated {
    color: #666;
  }
  
  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
  
  .tag {
    background: #333;
    color: #aaa;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }
  
  .cover {
    width: 100%;
    max-height: 400px;
    object-fit: contain;
    background: #1a1a1a;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  
  .content {
    line-height: 1.8;
    color: #ddd;
  }
  
  .content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }
  
  .content :global(h1),
  .content :global(h2),
  .content :global(h3) {
    color: #fff;
  }
  
  .content :global(h2) {
    margin-top: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #333;
  }
  
  .content :global(h3) {
    margin-top: 1.5rem;
  }
  
  .content :global(pre) {
    background: #0d0d0d;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1rem 0;
    border: 1px solid #333;
  }
  
  .content :global(code) {
    background: #2a2a2a;
    color: #e0e0e0;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
  }
  
  .content :global(pre code) {
    background: none;
    padding: 0;
  }
  
  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  
  .content :global(th),
  .content :global(td) {
    border: 1px solid #444;
    padding: 0.6rem 0.75rem;
    text-align: left;
  }
  
  .content :global(th) {
    background: #2a2a2a;
    color: #fff;
    font-weight: 600;
  }
  
  .content :global(td) {
    color: #ddd;
  }
  
  .content :global(hr) {
    border: none;
    border-top: 1px solid #333;
    margin: 2rem 0;
  }
  
  .content :global(blockquote) {
    border-left: 4px solid #444;
    margin: 1rem 0;
    padding-left: 1rem;
    color: #aaa;
  }
  
  .content :global(ul),
  .content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  
  .content :global(li) {
    margin: 0.3rem 0;
  }
  
  .content :global(a) {
    color: #6db3f2;
  }
  
  .content :global(a:hover) {
    text-decoration: underline;
  }
  
  .content :global(strong) {
    color: #fff;
  }
  
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #333;
  }
  
  footer a {
    color: #6db3f2;
  }
</style>
