---
import Base from '../../../layouts/Base.astro';
import { getDocuments, getProjects, getAssetUrl } from '../../../lib/directus';

export async function getStaticPaths() {
  const projects = await getProjects();
  const docs = await getDocuments();
  
  // プロジェクトIDの一覧を取得
  const projectIds = new Set(docs.map(d => d.project_id || 'none'));
  
  return [...projectIds].map(id => ({
    params: { id },
  }));
}

const { id } = Astro.params;
const docs = await getDocuments();
const projects = await getProjects();

const projectMap = new Map(projects.map(p => [p.id, p.name]));
const projectName = id === 'none' ? 'その他' : projectMap.get(id) || 'Unknown';

const projectDocs = docs.filter(d => (d.project_id || 'none') === id);

const clearanceLabels: Record<number, string> = {
  0: 'PUBLIC',
  1: 'INTERNAL',
  2: 'CONFIDENTIAL',
  3: 'SECRET',
  4: 'TOP SECRET',
  5: 'CLASSIFIED',
};

const clearanceColors: Record<number, string> = {
  0: '#4caf50',
  1: '#2196f3',
  2: '#ff9800',
  3: '#f44336',
  4: '#9c27b0',
  5: '#000000',
};
---

<Base title={`${projectName} - Docs`}>
  <main>
    <nav class="breadcrumb">
      <a href="/docs">Documents</a> / <span>{projectName}</span>
    </nav>
    
    <h1>{projectName}</h1>
    <p class="subtitle">{projectDocs.length}件のドキュメント</p>
    
    <div class="docs-grid">
      {projectDocs.map(doc => (
        <a href={`/docs/${doc.slug}`} class="doc-card">
          {doc.cover_image && (
            <img src={getAssetUrl(doc.cover_image)} alt={doc.title} class="cover" />
          )}
          <div class="content">
            <span class="clearance-badge" style={`background: ${clearanceColors[doc.clearance ?? 0]}`}>
              L{doc.clearance ?? 0}
            </span>
            <h3>{doc.title}</h3>
            <div class="meta">
              <time>{new Date(doc.date_created).toLocaleDateString('ja-JP')}</time>
              {doc.tags && doc.tags.length > 0 && (
                <div class="tags">
                  {doc.tags.slice(0, 2).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .breadcrumb {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 1rem;
  }
  
  .breadcrumb a {
    color: #6db3f2;
    text-decoration: none;
  }
  
  .breadcrumb a:hover {
    text-decoration: underline;
  }
  
  h1 {
    margin-bottom: 0.5rem;
    color: #fff;
  }
  
  .subtitle {
    color: #888;
    margin-bottom: 2rem;
  }
  
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  
  .doc-card {
    border: 1px solid #333;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: #1a1a1a;
    transition: border-color 0.2s, transform 0.2s;
  }
  
  .doc-card:hover {
    border-color: #555;
    transform: translateY(-2px);
  }
  
  .cover {
    width: 100%;
    height: 120px;
    object-fit: cover;
    background: #2a2a2a;
  }
  
  .content {
    padding: 1rem;
  }
  
  .clearance-badge {
    display: inline-block;
    color: white;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: bold;
    margin-bottom: 0.4rem;
  }
  
  .content h3 {
    font-size: 0.95rem;
    margin: 0 0 0.5rem 0;
    color: #fff;
  }
  
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: #666;
  }
  
  .tags {
    display: flex;
    gap: 0.25rem;
  }
  
  .tag {
    background: #333;
    color: #aaa;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }
</style>
