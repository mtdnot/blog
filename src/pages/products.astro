---
import Base from '../layouts/Base.astro';

const products = [
  {
    name: 'agentflow',
    note: 'OpenClaw のマルチエージェント向けに作ったビジュアル組織図エディタ。',
    links: [
      {
        label: 'dev.to',
        href: 'https://dev.to/mtdnot_9442010c0f26a0df93/i-built-a-visual-org-chart-editor-for-openclaw-multi-agent-systems-om7',
      },
    ],
  },
];
---

<Base title="Products">
  <h1>Products</h1>
  <p>公開しているアプリやプロダクトをまとめるページです。</p>

  {products.map((product) => (
    <section>
      <h2>{product.name}</h2>
      <p>{product.note}</p>
      <p>
        {product.links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </p>
    </section>
  ))}
</Base>
