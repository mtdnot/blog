---
import Base from '../../layouts/Base.astro';
import { getDocuments } from '../../lib/directus';
import { marked } from 'marked';

export async function getStaticPaths() {
  const docs = await getDocuments();
  const publicDocs = docs.filter(d => d.clearance === 0);
  return publicDocs.map(doc => ({
    params: { slug: doc.slug },
    props: { doc }
  }));
}

const { doc } = Astro.props;

// Directus画像URLをローカルパスに変換
let content = doc.content || '';
content = content.replace(
  /https:\/\/directus\.mtdnot\.dev\/assets\/([a-f0-9-]+)/g,
  '/images/directus/$1.png'
);

// 最初の画像をOGP用に抽出
const imageMatch = content.match(/!\[.*?\]\((\/images\/directus\/[^)]+)\)/);
const ogImage = imageMatch ? `https://blog.mtdnot.dev${imageMatch[1]}` : '';

const html = marked.parse(content);
---

<Base title={doc.title} description={doc.summary || ''} image={ogImage}>
  <article class="post-content">
    <header class="post-header">
      <h1>{doc.title}</h1>
      {doc.summary && <p class="summary">{doc.summary}</p>}
      <time>{new Date(doc.date_created).toLocaleDateString('ja-JP')}</time>
    </header>
    <div class="content" set:html={html} />
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #333;
  }
  .post-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .summary {
    color: #888;
    font-size: 1.1rem;
  }
  time {
    color: #666;
    font-size: 0.9rem;
  }
  .content {
    line-height: 1.8;
  }
  .content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1rem 0;
  }
  .content :global(pre) {
    background: #1e1e1e;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
  .content :global(code) {
    background: #2d2d2d;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }
  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  .content :global(th), .content :global(td) {
    border: 1px solid #333;
    padding: 0.5rem;
  }
  .content :global(th) {
    background: #21262d;
  }
</style>
