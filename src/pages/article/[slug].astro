---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { categoryMeta } from '../../lib/categories';
import Toc from '../../components/Toc.astro';
import { ui } from '../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const category = categoryMeta[post.data.category];
const t = ui.ja;
---

<Base title={post.data.title} description={post.data.description || ''}>
  <article class="post-layout">
    <div class="post-main">
      <header class="post-header">
        <nav class="crumbs">
          <a href="/">ホーム</a>
          <span>/</span>
          <a href={`/${post.data.category}/`}>{category.label.ja}</a>
          <span>/</span>
          <span>{post.data.title}</span>
        </nav>
        {post.data.thumbnail ? (
          <img src={post.data.thumbnail} alt={post.data.title} class="post-thumb" />
        ) : (
          <div class="post-thumb post-thumb-fallback" aria-label="thumbnail missing">no image</div>
        )}
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="summary">{post.data.description}</p>}
        <time>{`${post.data.date.getFullYear()}:${String(post.data.date.getMonth() + 1).padStart(2, '0')}:${String(post.data.date.getDate()).padStart(2, '0')}`}</time>
      </header>
      <div class="content">
        <Content />
      </div>
    </div>
    <Toc headings={headings} title={t.toc} />
  </article>
</Base>

<style>
  .crumbs {
    display: flex;
    gap: 0.45rem;
    color: #666;
    font-size: 0.85rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .crumbs a {
    color: #7d7d7d;
    text-decoration: none;
  }

  .post-thumb {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid #2f2f2f;
    background: #1c1c1c;
    margin-bottom: 1rem;
  }

  .post-thumb-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6f6f6f;
    font-size: 1.1rem;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #333;
  }
  .post-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .summary {
    color: #888;
    font-size: 1.1rem;
  }
  time {
    color: #666;
    font-size: 0.9rem;
  }
  .content {
    line-height: 1.8;
  }
  .content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1rem 0;
  }
  .content :global(pre) {
    background: #1e1e1e;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }
  .content :global(code) {
    background: #2d2d2d;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }
  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  .content :global(th), .content :global(td) {
    border: 1px solid #333;
    padding: 0.5rem;
  }
  .content :global(th) {
    background: #21262d;
  }
</style>
